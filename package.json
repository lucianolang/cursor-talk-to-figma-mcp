{
  "name": "figma-plugin-cli",
  "description": "Figma CLI bridge for AI agents",
  "version": "0.3.6",
  "module": "dist/figma.cjs",
  "main": "dist/figma.cjs",
  "bin": {
    "figma-cli": "dist/figma.cjs"
  },
  "files": [
    "dist",
    "skills",
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "start": "node dist/figma.cjs",
    "socket": "bun run src/socket.ts",
    "setup": "./scripts/setup.sh",
    "build": "tsup && cp dist/figma.cjs skills/figma-cli/scripts/figma.bundle.cjs",
    "build:watch": "tsup --watch",
    "dev": "bun run build:watch",
    "pub:release": "bun run build && npm publish"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "^1.2.5",
    "tsup": "^8.4.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "ws": "latest"
  }
}
